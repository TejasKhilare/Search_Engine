from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session
from pydantic import BaseModel

from core.deps import get_current_user       
from db.postgres import get_db
from db.models import Document, User
from services.embedding import embed_query
from vector_store.qdrant_client import search_vectors
from services.rag_service import generate_answer

router = APIRouter(prefix="/api", tags=["rag"])

MAX_QUERY_CHARS = 1000


class RagRequest(BaseModel):
    query: str
    doc_id: str | None = None
    top_k: int = 5


@router.post("/ai-search")
def ai_search(
    request: RagRequest,
    db: Session = Depends(get_db),
    user: User = Depends(get_current_user),
):
    query = request.query.strip()

    if not query:
        raise HTTPException(status_code=400, detail="Query cannot be empty")

    # reject queries that are too long before hitting any external API
    if len(query) > MAX_QUERY_CHARS:
        raise HTTPException(
            status_code=400,
            detail=f"Query too long ({len(query)} chars). Maximum allowed: {MAX_QUERY_CHARS}.",
        )

    # get user's documents
    user_docs = db.query(Document).filter(
        Document.user_id == user.id
    ).all()

    allowed_doc_ids = {doc.doc_id for doc in user_docs}

    if request.doc_id:
        if request.doc_id not in allowed_doc_ids:
            raise HTTPException(status_code=403, detail="Access denied")
        allowed_doc_ids = {request.doc_id}

    # embed query
    try:
        query_vector = embed_query(query)
    except Exception as e:
        raise HTTPException(status_code=500, detail="Embedding failed") from e

    # retrieve chunks
    try:
        hits = search_vectors(
            query_vector=query_vector,
            doc_id=None,
            top_k=request.top_k,
        )
    except Exception as e:
        raise HTTPException(status_code=500, detail="Vector search failed") from e

    # filter hits to user's documents
    filtered_hits = [
        hit for hit in hits
        if hit.payload and hit.payload.get("doc_id") in allowed_doc_ids
    ]

    if not filtered_hits:
        return {
            "answer": "No relevant information found.",
            "sources": [],
        }

    # extract contexts
    contexts = []
    sources = []

    for hit in filtered_hits:
        payload = hit.payload or {}
        content = str(payload.get("content", ""))

        if content.strip():
            contexts.append(content)
            sources.append({
                "doc_id": str(payload.get("doc_id", "")),
                "page_no": int(payload.get("page_no", 0)),
                "content": content,
            })

    # generate answer — generate_answer now raises on LLM failure
    try:
        answer = generate_answer(query, contexts)
    except Exception as e:
        raise HTTPException(status_code=500, detail="Answer generation failed") from e

    return {
        "query": query,
        "answer": answer,
        "sources": sources,
    }
