/* @import MUST come before @tailwind directives — PostCSS requirement */
@import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --bg-primary: #0f0f13;
  --bg-secondary: #16161d;
  --bg-card: #1c1c26;
  --bg-hover: #22222f;
  --border: #2a2a38;
  --border-light: #353548;
  --accent: #7c6af7;
  --accent-glow: rgba(124, 106, 247, 0.25);
  --accent-hover: #9585ff;
  --success: #22c55e;
  --warning: #f59e0b;
  --error: #ef4444;
  --text-primary: #e8e8f0;
  --text-secondary: #8888a8;
  --text-muted: #55556a;
  --sidebar-w: 280px;
}

* {
  box-sizing: border-box;
}

body {
  font-family: 'Sora', sans-serif;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  margin: 0;
  padding: 0;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}

code, pre, .mono {
  font-family: 'JetBrains Mono', monospace;
}

/* Scrollbar */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: var(--bg-primary); }
::-webkit-scrollbar-thumb { background: var(--border-light); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--accent); }

/* Status badge */
.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 2px 8px;
  border-radius: 100px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.02em;
}
.status-badge::before {
  content: '';
  width: 6px;
  height: 6px;
  border-radius: 50%;
}
.status-completed { background: rgba(34,197,94,0.12); color: #22c55e; }
.status-completed::before { background: #22c55e; }
.status-processing { background: rgba(245,158,11,0.12); color: #f59e0b; animation: pulse-status 1.5s infinite; }
.status-processing::before { background: #f59e0b; }
.status-pending { background: rgba(136,136,168,0.12); color: #8888a8; }
.status-pending::before { background: #8888a8; }
.status-failed { background: rgba(239,68,68,0.12); color: #ef4444; }
.status-failed::before { background: #ef4444; }

@keyframes pulse-status {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* Shimmer loading */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.shimmer {
  background: linear-gradient(90deg, var(--bg-card) 25%, var(--bg-hover) 50%, var(--bg-card) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

/* Spin animation */
@keyframes spin {
  to { transform: rotate(360deg); }
}
.spin { animation: spin 0.8s linear infinite; }

/* Fade in */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
.fade-in { animation: fadeIn 0.25s ease forwards; }

/* Toast */
.toast-container {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  gap: 8px;
  pointer-events: none;
}
.toast {
  padding: 12px 16px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
  border: 1px solid;
  pointer-events: all;
  animation: fadeIn 0.2s ease;
  max-width: 320px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
}
.toast-success { background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.3); color: #22c55e; }
.toast-error { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.3); color: #ef4444; }
.toast-info { background: rgba(124,106,247,0.1); border-color: rgba(124,106,247,0.3); color: #9585ff; }

/* react-pdf overrides */
.react-pdf__Page { background: transparent !important; }
.react-pdf__Page canvas { border-radius: 8px; box-shadow: 0 4px 32px rgba(0,0,0,0.5); max-width: 100%; }

/* ── Mobile responsive ────────────────────────────────────────────────────── */

/* On mobile: hide sidebar by default (MainLayout handles show/hide via transform) */
@media (max-width: 767px) {
  :root {
    --sidebar-w: 260px;
  }

  /* Results list takes full width on mobile */
  .results-list-panel {
    width: 100% !important;
    border-right: none !important;
  }

  /* PDF area takes full width on mobile */
  .pdf-area-panel {
    width: 100% !important;
    padding: 8px !important;
  }

  /* Hide "Sign out" text on very small screens, keep icon */
  .logout-text { display: none; }

  /* Shrink nav link labels on mobile */
  .nav-link-text { display: none; }

  /* Toast smaller on mobile */
  .toast-container {
    bottom: 12px;
    right: 12px;
    left: 12px;
  }
  .toast {
    max-width: 100%;
  }
}

@media (max-width: 400px) {
  /* Very small phones */
  :root {
    --sidebar-w: 85vw;
  }
}
